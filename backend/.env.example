# Copy to ".env" and fill in real values. Do not commit ".env".

# ── CORS (optional) ────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the API (any host/port).
# Example if Vite uses 5176: http://localhost:5176,http://127.0.0.1:5176
# CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Local database (default local-first) ───────────────────────────
# SQLite works out of the box for localhost development.
DATABASE_URL=sqlite:///./finance_dashboard.db

# ── Local upload archive (optional override) ───────────────────────
# Uploaded CSVs are copied to backend/uploads by default.
# LOCAL_UPLOAD_DIR=./uploads

# /api/explain now runs fully local deterministic logic.
